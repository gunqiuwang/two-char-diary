/* pages/history/history.wxss */

.history-page {
  min-height: 100vh;
  background-color: #f5f4ed;
  padding: 40rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.history-item {
  background: #faf9f5;
  border: 1rpx solid #e8e6dc;
  border-radius: 4rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
}

.item-date {
  font-size: 24rpx;
  color: #6b6a64;
  width: 180rpx;
  letter-spacing: 2rpx;
}

.item-words {
  font-size: 36rpx;
  font-weight: 400;
  color: #2F312B;
  flex: 1;
  letter-spacing: 6rpx;
  font-family: "STSong", "Songti SC", "PingFang SC", serif;
}

.item-hexagram {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.item-yao-group {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.mini-yao {
  width: 48rpx;
  height: 4rpx;
  background: #4A4A45;
  border-radius: 2rpx;
}

.mini-yao.yin {
  width: 20rpx;
  margin-left: 28rpx;
}

.item-name {
  font-size: 20rpx;
  color: #8A8A82;
  letter-spacing: 2rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6b6a64;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #b8b6ae;
}
